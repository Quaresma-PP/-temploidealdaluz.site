{
  "outputDirectory": ".",
  "redirects": [
    { "source": "/", "destination": "/login/", "permanent": false },
    { "source": "/login", "destination": "/login/", "permanent": false },
    { "source": "/inicio-oracoes-principal", "destination": "/inicio-oracoes-principal/", "permanent": false },
    { "source": "/poder-dos-arcanjos", "destination": "/poder-dos-arcanjos/", "permanent": false },
    { "source": "/grimorio-dos-arcanjos", "destination": "/grimorio-dos-arcanjos/", "permanent": false },
    { "source": "/30-oracoes-sao-francisco", "destination": "/30-oracoes-sao-francisco/", "permanent": false },
    { "source": "/musicas-dos-anjos-premium", "destination": "/musicas-dos-anjos-premium/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
